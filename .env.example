# ── IQStudio Backend — Environment Variables ──────────────────────────────────
# Copy to .env for local dev. On Railway, set these in the Variables panel.

PORT=3000
NODE_ENV=production

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string

# AI keys
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Hybrid mode — set to your Cloudflare Pages URL (enables CORS + disables static serving)
# e.g. https://iqstudio.pages.dev
FRONTEND_ORIGIN=https://your-project.pages.dev

# Self-referential URL (used in callbacks)
APP_URL=https://your-backend.up.railway.app
